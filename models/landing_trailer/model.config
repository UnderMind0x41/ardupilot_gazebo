<?xml version="1.0"?>
<model>
  <name>Landing Trailer</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Standalone dynamic landing trailer with passive wheel joints and a NavSat GPS sensor.
    The deck features a clearly marked landing pad (H symbol) and can also be reused independently of the truck rig.
    Origin: center-bottom of the trailer bed at ground level.
  </description>
</model>
