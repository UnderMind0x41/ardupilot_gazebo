<?xml version="1.0"?>
<model>
  <name>Landing Trailer</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Detached flatbed trailer serving as a secondary drone landing/takeoff base.
    Equipped with a NavSat GPS sensor that broadcasts coordinates via Gazebo topics.
    The deck features a clearly marked landing pad (H symbol).
    Origin: center-bottom of the trailer bed at ground level.
  </description>
</model>
