<?xml version="1.0" ?>
<!--
  Model: landing_trailer
  Description: Standalone dynamic trailer with passive wheel joints.

  Coordinate system (model frame):
    +X = forward (tongue / coupler end)
    +Y = left side
    +Z = Up
    Origin = center of trailer bed at ground level

  Gazebo topic:
    /world/<world>/model/landing_trailer/link/base_link/sensor/gps_sensor/navsat
-->
<sdf version="1.9">
  <model name="landing_trailer">
    <static>false</static>
    <self_collide>false</self_collide>

    <link name="base_link">
      <inertial>
        <mass>1300.0</mass>
        <inertia>
          <ixx>1100.0</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>4200.0</iyy>
          <iyz>0.0</iyz>
          <izz>4600.0</izz>
        </inertia>
      </inertial>
      <velocity_decay>
        <linear>0.30</linear>
        <angular>2.10</angular>
      </velocity_decay>

      <visual name="frame_rail_left">
        <pose>0 1.1 1.1 0 0 0</pose>
        <geometry><box><size>6.1 0.14 0.35</size></box></geometry>
        <material>
          <ambient>0.22 0.22 0.22 1</ambient>
          <diffuse>0.22 0.22 0.22 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="frame_rail_left_col">
        <pose>0 1.1 1.1 0 0 0</pose>
        <geometry><box><size>6.1 0.14 0.35</size></box></geometry>
      </collision>

      <visual name="frame_rail_right">
        <pose>0 -1.1 1.1 0 0 0</pose>
        <geometry><box><size>6.1 0.14 0.35</size></box></geometry>
        <material>
          <ambient>0.22 0.22 0.22 1</ambient>
          <diffuse>0.22 0.22 0.22 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="frame_rail_right_col">
        <pose>0 -1.1 1.1 0 0 0</pose>
        <geometry><box><size>6.1 0.14 0.35</size></box></geometry>
      </collision>

      <visual name="cross_beam_rear">
        <pose>-2.4 0 1.05 0 0 0</pose>
        <geometry><box><size>0.14 2.35 0.28</size></box></geometry>
        <material>
          <ambient>0.22 0.22 0.22 1</ambient>
          <diffuse>0.22 0.22 0.22 1</diffuse>
        </material>
      </visual>
      <collision name="cross_beam_rear_col">
        <pose>-2.4 0 1.05 0 0 0</pose>
        <geometry><box><size>0.14 2.35 0.28</size></box></geometry>
      </collision>

      <visual name="cross_beam_front">
        <pose>2.4 0 1.05 0 0 0</pose>
        <geometry><box><size>0.14 2.35 0.28</size></box></geometry>
        <material>
          <ambient>0.22 0.22 0.22 1</ambient>
          <diffuse>0.22 0.22 0.22 1</diffuse>
        </material>
      </visual>
      <collision name="cross_beam_front_col">
        <pose>2.4 0 1.05 0 0 0</pose>
        <geometry><box><size>0.14 2.35 0.28</size></box></geometry>
      </collision>

      <visual name="cross_beam_mid">
        <pose>0 0 1.05 0 0 0</pose>
        <geometry><box><size>0.14 2.35 0.28</size></box></geometry>
        <material>
          <ambient>0.22 0.22 0.22 1</ambient>
          <diffuse>0.22 0.22 0.22 1</diffuse>
        </material>
      </visual>
      <collision name="cross_beam_mid_col">
        <pose>0 0 1.05 0 0 0</pose>
        <geometry><box><size>0.14 2.35 0.28</size></box></geometry>
      </collision>

      <visual name="trailer_bed">
        <pose>0 0 1.34 0 0 0</pose>
        <geometry><box><size>6.1 2.55 0.12</size></box></geometry>
        <material>
          <ambient>0.42 0.42 0.42 1</ambient>
          <diffuse>0.40 0.40 0.40 1</diffuse>
          <specular>0.08 0.08 0.08 1</specular>
        </material>
      </visual>
      <collision name="trailer_bed_col">
        <pose>0 0 1.34 0 0 0</pose>
        <geometry><box><size>6.1 2.55 0.12</size></box></geometry>
      </collision>

      <visual name="trailer_rear_board">
        <pose>-3.11 0 1.52 0 0 0</pose>
        <geometry><box><size>0.10 2.55 0.28</size></box></geometry>
        <material>
          <ambient>0.30 0.30 0.30 1</ambient>
          <diffuse>0.28 0.28 0.28 1</diffuse>
        </material>
      </visual>
      <collision name="trailer_rear_board_col">
        <pose>-3.11 0 1.52 0 0 0</pose>
        <geometry><box><size>0.10 2.55 0.28</size></box></geometry>
      </collision>

      <visual name="rear_light_left">
        <pose>-3.12 0.95 1.47 0 0 0</pose>
        <geometry><box><size>0.08 0.16 0.10</size></box></geometry>
        <material>
          <ambient>0.90 0.10 0.05 1</ambient>
          <diffuse>0.88 0.08 0.04 1</diffuse>
        </material>
      </visual>
      <visual name="rear_light_right">
        <pose>-3.12 -0.95 1.47 0 0 0</pose>
        <geometry><box><size>0.08 0.16 0.10</size></box></geometry>
        <material>
          <ambient>0.90 0.10 0.05 1</ambient>
          <diffuse>0.88 0.08 0.04 1</diffuse>
        </material>
      </visual>

      <visual name="tongue_main">
        <pose>3.6 0 0.85 0 0 0</pose>
        <geometry><box><size>1.10 0.22 0.16</size></box></geometry>
        <material>
          <ambient>0.25 0.25 0.25 1</ambient>
          <diffuse>0.22 0.22 0.22 1</diffuse>
        </material>
      </visual>
      <collision name="tongue_main_col">
        <pose>3.6 0 0.85 0 0 0</pose>
        <geometry><box><size>1.10 0.22 0.16</size></box></geometry>
      </collision>

      <visual name="landing_pad_bg">
        <pose>0 0 1.406 0 0 0</pose>
        <geometry><box><size>2.6 2.6 0.008</size></box></geometry>
        <material>
          <ambient>0.95 0.82 0.0 1</ambient>
          <diffuse>0.95 0.82 0.0 1</diffuse>
          <specular>0.15 0.12 0.0 1</specular>
        </material>
      </visual>
      <visual name="landing_pad_h_bar">
        <pose>0 0 1.411 0 0 0</pose>
        <geometry><box><size>0.28 2.2 0.002</size></box></geometry>
        <material>
          <ambient>1.0 1.0 1.0 1</ambient>
          <diffuse>1.0 1.0 1.0 1</diffuse>
        </material>
      </visual>
      <visual name="landing_pad_h_left">
        <pose>0 0.76 1.411 0 0 0</pose>
        <geometry><box><size>2.2 0.28 0.002</size></box></geometry>
        <material>
          <ambient>1.0 1.0 1.0 1</ambient>
          <diffuse>1.0 1.0 1.0 1</diffuse>
        </material>
      </visual>
      <visual name="landing_pad_h_right">
        <pose>0 -0.76 1.411 0 0 0</pose>
        <geometry><box><size>2.2 0.28 0.002</size></box></geometry>
        <material>
          <ambient>1.0 1.0 1.0 1</ambient>
          <diffuse>1.0 1.0 1.0 1</diffuse>
        </material>
      </visual>

      <visual name="gps_mount_base">
        <pose>1.0 0 1.430 0 0 0</pose>
        <geometry><box><size>0.10 0.10 0.04</size></box></geometry>
        <material>
          <ambient>0.30 0.30 0.30 1</ambient>
          <diffuse>0.28 0.28 0.28 1</diffuse>
        </material>
      </visual>
      <visual name="gps_head">
        <pose>1.0 0 1.474 0 0 0</pose>
        <geometry><cylinder><radius>0.065</radius><length>0.048</length></cylinder></geometry>
        <material>
          <ambient>0.90 0.90 0.90 1</ambient>
          <diffuse>0.88 0.88 0.88 1</diffuse>
          <specular>0.4 0.4 0.4 1</specular>
        </material>
      </visual>
      <visual name="gps_led">
        <pose>1.0 0 1.502 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.008</length></cylinder></geometry>
        <material>
          <ambient>0.0 0.9 0.2 1</ambient>
          <diffuse>0.0 0.9 0.2 1</diffuse>
        </material>
      </visual>

      <sensor name="gps_sensor" type="navsat">
        <pose>1.0 0 1.474 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>1.0</update_rate>
        <navsat>
          <position_sensing>
            <horizontal>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.001</stddev></noise>
            </horizontal>
            <vertical>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.002</stddev></noise>
            </vertical>
          </position_sensing>
          <velocity_sensing>
            <horizontal>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.05</stddev></noise>
            </horizontal>
            <vertical>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.05</stddev></noise>
            </vertical>
          </velocity_sensing>
        </navsat>
      </sensor>
    </link>

    <link name="coupler_link">
      <pose>4.18 0 0.82 0 0 0</pose>
      <inertial>
        <mass>10.0</mass>
        <inertia>
          <ixx>0.03</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.03</iyy>
          <iyz>0.0</iyz>
          <izz>0.03</izz>
        </inertia>
      </inertial>
      <visual name="coupler">
        <geometry><sphere><radius>0.09</radius></sphere></geometry>
        <material>
          <ambient>0.55 0.55 0.60 1</ambient>
          <diffuse>0.50 0.50 0.55 1</diffuse>
          <specular>0.6 0.6 0.65 1</specular>
        </material>
      </visual>
      <collision name="coupler_col">
        <geometry><sphere><radius>0.07</radius></sphere></geometry>
      </collision>
    </link>
    <joint name="coupler_fixed_joint" type="fixed">
      <parent>base_link</parent>
      <child>coupler_link</child>
    </joint>

    <link name="wheel_rear_left">
      <pose>-2.0 1.38 0.50 -1.5708 0 0</pose>
      <inertial>
        <mass>35.0</mass>
        <inertia>
          <ixx>2.8</ixx>
          <iyy>2.8</iyy>
          <izz>3.6</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>4.0</mu>
              <mu2>4.0</mu2>
              <fdir1>0 0 1</fdir1>
              <slip1>0.002</slip1>
              <slip2>0.004</slip2>
            </ode>
            <bullet>
                <friction>4.0</friction>
                <friction2>4.0</friction2>
                <rolling_friction>0.90</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </link>
    <link name="wheel_rear_right">
      <pose>-2.0 -1.38 0.50 -1.5708 0 0</pose>
      <inertial>
        <mass>35.0</mass>
        <inertia>
          <ixx>2.8</ixx>
          <iyy>2.8</iyy>
          <izz>3.6</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>4.0</mu>
              <mu2>4.0</mu2>
              <fdir1>0 0 1</fdir1>
              <slip1>0.002</slip1>
              <slip2>0.004</slip2>
            </ode>
            <bullet>
                <friction>4.0</friction>
                <friction2>4.0</friction2>
                <rolling_friction>0.90</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </link>
    <link name="wheel_front_left">
      <pose>2.0 1.38 0.50 -1.5708 0 0</pose>
      <inertial>
        <mass>35.0</mass>
        <inertia>
          <ixx>2.8</ixx>
          <iyy>2.8</iyy>
          <izz>3.6</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.02</mu>
              <mu2>0.02</mu2>
              <fdir1>0 0 1</fdir1>
              <slip1>1.5</slip1>
              <slip2>2.0</slip2>
            </ode>
            <bullet>
                <friction>0.02</friction>
                <friction2>0.02</friction2>
                <rolling_friction>0.0</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </link>
    <link name="wheel_front_right">
      <pose>2.0 -1.38 0.50 -1.5708 0 0</pose>
      <inertial>
        <mass>35.0</mass>
        <inertia>
          <ixx>2.8</ixx>
          <iyy>2.8</iyy>
          <izz>3.6</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.02</mu>
              <mu2>0.02</mu2>
              <fdir1>0 0 1</fdir1>
              <slip1>1.5</slip1>
              <slip2>2.0</slip2>
            </ode>
            <bullet>
                <friction>0.02</friction>
                <friction2>0.02</friction2>
                <rolling_friction>0.0</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="wheel_rear_left_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_rear_left</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <damping>12.0</damping>
          <friction>8.0</friction>
        </dynamics>
      </axis>
    </joint>
    <joint name="wheel_rear_right_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_rear_right</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <damping>12.0</damping>
          <friction>8.0</friction>
        </dynamics>
      </axis>
    </joint>
    <joint name="wheel_front_left_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_front_left</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <damping>0.2</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>
    <joint name="wheel_front_right_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_front_right</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <damping>0.2</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <plugin
      filename="gz-sim-wheel-slip-system"
      name="gz::sim::systems::WheelSlip">
      <wheel link_name="wheel_rear_left">
        <wheel_radius>0.50</wheel_radius>
        <slip_compliance_lateral>0.03</slip_compliance_lateral>
        <slip_compliance_longitudinal>0.001</slip_compliance_longitudinal>
        <wheel_normal_force>11000</wheel_normal_force>
      </wheel>
      <wheel link_name="wheel_rear_right">
        <wheel_radius>0.50</wheel_radius>
        <slip_compliance_lateral>0.03</slip_compliance_lateral>
        <slip_compliance_longitudinal>0.001</slip_compliance_longitudinal>
        <wheel_normal_force>11000</wheel_normal_force>
      </wheel>
      <wheel link_name="wheel_front_left">
        <wheel_radius>0.50</wheel_radius>
        <slip_compliance_lateral>8.0</slip_compliance_lateral>
        <slip_compliance_longitudinal>4.0</slip_compliance_longitudinal>
        <wheel_normal_force>1500</wheel_normal_force>
      </wheel>
      <wheel link_name="wheel_front_right">
        <wheel_radius>0.50</wheel_radius>
        <slip_compliance_lateral>8.0</slip_compliance_lateral>
        <slip_compliance_longitudinal>4.0</slip_compliance_longitudinal>
        <wheel_normal_force>1500</wheel_normal_force>
      </wheel>
    </plugin>
  </model>
</sdf>
