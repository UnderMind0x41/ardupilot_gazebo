    <joint name="trailer_rear_left_wheel_joint" type="revolute">
      <parent>trailer_base_link</parent>
      <child>trailer_rear_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <damping>0.8</damping>
        </dynamics>
      </axis>
    </joint>
    <joint name="trailer_rear_right_wheel_joint" type="revolute">
      <parent>trailer_base_link</parent>
      <child>trailer_rear_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <damping>0.8</damping>
        </dynamics>
      </axis>
    </joint>
    <joint name="trailer_front_left_wheel_joint" type="revolute">
      <parent>trailer_base_link</parent>
      <child>trailer_front_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <damping>0.8</damping>
        </dynamics>
      </axis>
    </joint>
    <joint name="trailer_front_right_wheel_joint" type="revolute">
      <parent>trailer_base_link</parent>
      <child>trailer_front_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <damping>0.8</damping>
        </dynamics>
      </axis>
    </joint>

    <plugin
      filename="gz-sim-ackermann-steering-system"
      name="gz::sim::systems::AckermannSteering">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <left_steering_joint>front_left_steering_joint</left_steering_joint>
      <right_steering_joint>front_right_steering_joint</right_steering_joint>
      <kingpin_width>2.74</kingpin_width>
      <steering_limit>0.50</steering_limit>
      <wheel_base>3.70</wheel_base>
      <wheel_separation>2.74</wheel_separation>
      <wheel_radius>0.50</wheel_radius>
      <min_velocity>-2.0</min_velocity>
      <max_velocity>6.0</max_velocity>
      <min_acceleration>-3.5</min_acceleration>
      <max_acceleration>2.5</max_acceleration>
    </plugin>

    <!-- Keyboard teleop via Gazebo KeyPublisher (W/A/S/D + X/Space stop) -->
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress">
        <match field="data">87</match>
      </input>
      <output type="gz.msgs.Twist" topic="/model/landing_truck/cmd_vel">
        linear: {x: 2.6}, angular: {z: 0.0}
      </output>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress">
        <match field="data">65</match>
      </input>
      <output type="gz.msgs.Twist" topic="/model/landing_truck/cmd_vel">
        linear: {x: 1.8}, angular: {z: 0.30}
      </output>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress">
        <match field="data">83</match>
      </input>
      <output type="gz.msgs.Twist" topic="/model/landing_truck/cmd_vel">
        linear: {x: -1.4}, angular: {z: 0.0}
      </output>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress">
        <match field="data">68</match>
      </input>
      <output type="gz.msgs.Twist" topic="/model/landing_truck/cmd_vel">
        linear: {x: 1.8}, angular: {z: -0.30}
      </output>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress">
        <match field="data">88</match>
      </input>
      <output type="gz.msgs.Twist" topic="/model/landing_truck/cmd_vel">
        linear: {x: 0.0}, angular: {z: 0.0}
      </output>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress">
        <match field="data">32</match>
      </input>
      <output type="gz.msgs.Twist" topic="/model/landing_truck/cmd_vel">
        linear: {x: 0.0}, angular: {z: 0.0}
      </output>
    </plugin>
  </model>
</sdf>
