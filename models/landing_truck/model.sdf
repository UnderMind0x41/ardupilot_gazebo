    <link name="trailer_front_right_wheel">
      <pose>-6.8 -1.38 0.50 -1.5708 0 0</pose>
      <inertial>
        <mass>65.0</mass>
        <inertia>
          <ixx>5.5</ixx>
          <iyy>5.5</iyy>
          <izz>7.0</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.6</mu>
              <mu2>2.4</mu2>
              <fdir1>0 0 1</fdir1>
            </ode>
            <bullet>
              <friction>1.6</friction>
              <friction2>2.4</friction2>
