      <collision name="trailer_bed_col">
        <pose>0 0 1.34 0 0 0</pose>
        <geometry><box><size>6.1 2.55 0.12</size></box></geometry>
      </collision>

      <visual name="trailer_rear_board">
        <pose>-3.11 0 1.52 0 0 0</pose>
        <geometry><box><size>0.10 2.55 0.28</size></box></geometry>
        <material>
