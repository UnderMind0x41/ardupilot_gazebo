<?xml version="1.0" ?>
<!--
  Model: landing_truck
  Description: Drivable landing truck with an articulated rear trailer.

  Coordinate system (model frame):
    +X = East / forward
    +Y = North / left
    +Z = Up

  Key features:
    - Physics-based Ackermann steering on the truck axle
    - Rear trailer connected through a damped tow bar
    - Truck and trailer both react to gravity
    - Truck landing pad keeps drone 1 near its previous location
    - Trailer landing pad sits behind the truck for drone 2

  Gazebo topics:
    /model/landing_truck/cmd_vel
    /world/<world>/model/landing_truck/link/base_link/sensor/gps_sensor/navsat
    /world/<world>/model/landing_truck/link/trailer_base_link/sensor/trailer_gps_sensor/navsat
-->
