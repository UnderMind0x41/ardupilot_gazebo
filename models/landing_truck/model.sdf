      </collision>

      <visual name="tongue_main">
        <pose>3.6 0 0.85 0 0 0</pose>
        <geometry><box><size>1.10 0.22 0.16</size></box></geometry>
        <material>
          <ambient>0.25 0.25 0.25 1</ambient>
          <diffuse>0.22 0.22 0.22 1</diffuse>
        </material>
      </visual>
      <collision name="tongue_main_col">
        <pose>3.6 0 0.85 0 0 0</pose>
        <geometry><box><size>1.10 0.22 0.16</size></box></geometry>
      </collision>

      <visual name="landing_pad_bg">
        <pose>0 0 1.406 0 0 0</pose>
        <geometry><box><size>2.6 2.6 0.008</size></box></geometry>
        <material>
          <ambient>0.95 0.82 0.0 1</ambient>
          <diffuse>0.95 0.82 0.0 1</diffuse>
          <specular>0.15 0.12 0.0 1</specular>
        </material>
      </visual>
      <visual name="landing_pad_h_bar">
        <pose>0 0 1.411 0 0 0</pose>
        <geometry><box><size>0.28 2.2 0.002</size></box></geometry>
        <material>
          <ambient>1.0 1.0 1.0 1</ambient>
          <diffuse>1.0 1.0 1.0 1</diffuse>
        </material>
      </visual>
      <visual name="landing_pad_h_left">
        <pose>0 0.76 1.411 0 0 0</pose>
        <geometry><box><size>2.2 0.28 0.002</size></box></geometry>
        <material>
          <ambient>1.0 1.0 1.0 1</ambient>
          <diffuse>1.0 1.0 1.0 1</diffuse>
        </material>
      </visual>
      <visual name="landing_pad_h_right">
        <pose>0 -0.76 1.411 0 0 0</pose>
        <geometry><box><size>2.2 0.28 0.002</size></box></geometry>
        <material>
          <ambient>1.0 1.0 1.0 1</ambient>
          <diffuse>1.0 1.0 1.0 1</diffuse>
        </material>
      </visual>

      <visual name="gps_mount_base">
        <pose>1.0 0 1.430 0 0 0</pose>
        <geometry><box><size>0.10 0.10 0.04</size></box></geometry>
        <material>
          <ambient>0.30 0.30 0.30 1</ambient>
          <diffuse>0.28 0.28 0.28 1</diffuse>
        </material>
      </visual>
      <visual name="gps_head">
        <pose>1.0 0 1.474 0 0 0</pose>
        <geometry><cylinder><radius>0.065</radius><length>0.048</length></cylinder></geometry>
        <material>
          <ambient>0.90 0.90 0.90 1</ambient>
          <diffuse>0.88 0.88 0.88 1</diffuse>
          <specular>0.4 0.4 0.4 1</specular>
        </material>
      </visual>
      <visual name="gps_led">
        <pose>1.0 0 1.502 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.008</length></cylinder></geometry>
        <material>
          <ambient>0.0 0.9 0.2 1</ambient>
          <diffuse>0.0 0.9 0.2 1</diffuse>
        </material>
      </visual>

      <sensor name="trailer_gps_sensor" type="navsat">
        <pose>1.0 0 1.474 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>1.0</update_rate>
        <navsat>
          <position_sensing>
            <horizontal>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.001</stddev></noise>
            </horizontal>
            <vertical>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.002</stddev></noise>
            </vertical>
          </position_sensing>
          <velocity_sensing>
            <horizontal>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.05</stddev></noise>
            </horizontal>
            <vertical>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.05</stddev></noise>
            </vertical>
          </velocity_sensing>
        </navsat>
      </sensor>
    </link>

    <link name="trailer_coupler_link">
      <pose>-4.62 0 0.82 0 0 0</pose>
      <inertial>
        <mass>10.0</mass>
        <inertia>
          <ixx>0.03</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.03</iyy>
          <iyz>0.0</iyz>
          <izz>0.03</izz>
        </inertia>
      </inertial>
      <visual name="coupler">
        <geometry><sphere><radius>0.09</radius></sphere></geometry>
        <material>
          <ambient>0.55 0.55 0.60 1</ambient>
          <diffuse>0.50 0.50 0.55 1</diffuse>
          <specular>0.6 0.6 0.65 1</specular>
        </material>
      </visual>
      <collision name="coupler_col">
        <geometry><sphere><radius>0.07</radius></sphere></geometry>
      </collision>
    </link>
    <joint name="trailer_coupler_fixed_joint" type="fixed">
      <parent>trailer_coupler_link</parent>
      <child>trailer_base_link</child>
    </joint>

    <!-- Tow bar / wire -->
    <link name="tow_bar_link">
      <pose>-3.0 0 0.90 0 0 0</pose>
      <inertial>
        <mass>40.0</mass>
        <inertia>
          <ixx>0.05</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>8.0</iyy>
          <iyz>0.0</iyz>
          <izz>8.0</izz>
        </inertia>
      </inertial>
      <visual name="tow_bar_visual">
        <pose>-0.81 0 0 0 1.5708 0</pose>
        <geometry><cylinder><radius>0.045</radius><length>1.62</length></cylinder></geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
          <specular>0.15 0.15 0.15 1</specular>
        </material>
      </visual>
      <collision name="tow_bar_col">
        <pose>-0.81 0 0 0 0 0</pose>
        <geometry><box><size>1.62 0.10 0.10</size></box></geometry>
      </collision>
    </link>
    <joint name="truck_to_tow_bar_joint" type="revolute">
      <parent>truck_hitch_link</parent>
      <child>tow_bar_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.5</lower>
          <upper>1.5</upper>
          <effort>1500</effort>
          <velocity>2.0</velocity>
        </limit>
        <dynamics>
          <damping>20.0</damping>
        </dynamics>
      </axis>
    </joint>

    <link name="tow_bar_rear_tip">
      <pose>-4.62 0 0.90 0 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.001</iyy>
          <iyz>0.0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
    </link>
    <joint name="tow_bar_rear_tip_fixed_joint" type="fixed">
      <parent>tow_bar_link</parent>
      <child>tow_bar_rear_tip</child>
    </joint>
    <joint name="tow_bar_to_trailer_joint" type="revolute">
      <parent>tow_bar_rear_tip</parent>
      <child>trailer_coupler_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.8</lower>
          <upper>1.8</upper>
          <effort>1500</effort>
          <velocity>2.0</velocity>
        </limit>
        <dynamics>
          <damping>18.0</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- Trailer wheels -->
    <link name="trailer_rear_left_wheel">
      <pose>-10.8 1.38 0.50 -1.5708 0 0</pose>
      <inertial>
        <mass>65.0</mass>
        <inertia>
          <ixx>5.5</ixx>
          <iyy>5.5</iyy>
          <izz>7.0</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.10 0.10 0.10 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.50</radius><length>0.26</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.6</mu>
              <mu2>2.4</mu2>
              <fdir1>0 0 1</fdir1>
            </ode>
            <bullet>
              <friction>1.6</friction>
              <friction2>2.4</friction2>
              <rolling_friction>0.04</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </link>
    <link name="trailer_rear_right_wheel">
      <pose>-10.8 -1.38 0.50 -1.5708 0 0</pose>
