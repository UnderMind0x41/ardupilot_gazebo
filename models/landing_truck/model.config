<?xml version="1.0"?>
<model>
  <name>Landing Truck</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Agricultural operations landing truck with Ackermann steering and an attached articulated trailer.
    Both the truck bed and the rear trailer carry drone landing pads and NavSat GPS sensors.
    Origin: truck model frame at ground level, with the trailer attached behind the truck.
  </description>
</model>
