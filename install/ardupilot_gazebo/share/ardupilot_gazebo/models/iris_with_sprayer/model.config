<?xml version="1.0"?>
<model>
  <name>iris_with_sprayer</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>

  <author>
    <name>Agri-Drone Project</name>
    <email></email>
  </author>

  <description>
    Iris quadcopter with dual agricultural sprayers (left and right nozzles).
    Sprayers produce a purple particle cloud when active and paint the treated
    ground area with semi-transparent purple discs.
    Control spraying via gz topic: /model/iris_with_sprayer/sprayer/cmd
    (gz.msgs.Boolean)
  </description>
</model>
