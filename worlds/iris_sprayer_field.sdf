        <visual name="row_22"><pose>0 15.75 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_23"><pose>0 17.25 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

      </link>
    </model>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!--  Trees — fetched from Gazebo Fuel on first run, then cached      -->
    <!--  Pine Tree  ≈ 877 KB  |  Oak tree  ≈ 589 KB                     -->
    <!-- ═════════════════════════════════════════════════════════════════ -->

    <!-- ── North edge ────────────────────────────────────────────────── -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine Tree</uri>
      <name>pine_n1</name><pose>-72 90 0 0 0 0.4</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Oak tree</uri>
      <name>oak_n1</name><pose>-44 97 0 0 0 1.1</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine Tree</uri>
      <name>pine_n2</name><pose>-12 93 0 0 0 2.5</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Oak tree</uri>
      <name>oak_n2</name><pose>18 91 0 0 0 0.8</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine Tree</uri>
      <name>pine_n3</name><pose>48 98 0 0 0 1.7</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Oak tree</uri>
