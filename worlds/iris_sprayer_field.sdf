      <name>f2_t08</name><pose>-128.9 17.0 0 0 0 3.9</pose></include>
    <include><uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine Tree</uri>
      <name>f2_t09</name><pose>-125.6 -33.6 0 0 0 0.8</pose></include>
    <include><uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Oak tree</uri>
      <name>f2_t10</name><pose>-103.1 -79.1 0 0 0 2.5</pose></include>
