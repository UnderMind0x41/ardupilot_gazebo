      <name>pine_se1</name><pose>82 -84 0 0 0 2.4</pose>
    </include>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!--  Forest — four concentric rings, radii 112 / 130 / 152 / 175 m  -->
    <!--  Placed beyond the current scatter trees (≤ 98 m).              -->
    <!--  Ring 1: 14 trees @ r≈112 m   (step ≈25.7 °, offset 7 °)       -->
    <!--  Ring 2: 16 trees @ r≈130 m   (step  22.5 °, offset 15 °)      -->
    <!--  Ring 3: 18 trees @ r≈152 m   (step  20.0 °, offset  3 °)      -->
    <!--  Ring 4: 20 trees @ r≈175 m   (step  18.0 °, offset 10 °)      -->
    <!--  Alternating Pine / Oak, each with a unique yaw.                -->
    <!-- ═════════════════════════════════════════════════════════════════ -->

    <!-- Ring 1  r=112 -->
    <include><uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine Tree</uri>
      <name>f1_t01</name><pose>111.2 13.6 0 0 0 0.5</pose></include>
    <include><uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Oak tree</uri>
