<?xml version="1.0" ?>
<!--
  World: iris_sprayer_field

  Realistic agricultural field environment for the Iris sprayer drone.

  - Grass ground plane  (500 × 500 m, dark-green material)
  - 24 crop rows       (50 m long, 1.5 m row pitch, 0.35 m wide, 0.12 m tall)
  - 25 scatter trees    around the field edge (r ≈ 80–98 m)
  - 68 forest trees     in 4 concentric rings (r ≈ 112 / 130 / 152 / 175 m)
  - Warm afternoon directional sun with soft sky fill
  - Blue sky + cloud layer

  All sprayer plugins match iris_sprayer.sdf exactly.

  On first launch Gazebo fetches the tree models from Fuel (~1-2 MB total)
  and caches them at  ~/.gz/fuel/  — subsequent runs are instant.

  Usage:
    GZ_WORLD=iris_sprayer_field.sdf ./scripts-no-docker/start_sim.sh
    GZ_WORLD=iris_sprayer_field.sdf docker compose up
-->
<sdf version="1.9">
  <world name="iris_sprayer_field">

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!--  Physics                                                          -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <physics name="1ms" type="ignore">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!--  Core systems                                                     -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <plugin filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics"/>

    <plugin filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <plugin filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands"/>

    <plugin filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster"/>

    <plugin filename="gz-sim-imu-system"
      name="gz::sim::systems::Imu"/>

    <plugin filename="gz-sim-navsat-system"
      name="gz::sim::systems::NavSat"/>

    <!--  Required for the sprayer particle emitters -->
    <plugin filename="gz-sim-particle-emitter-system"
      name="gz::sim::systems::ParticleEmitter"/>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!--  Scene, sky and lighting                                          -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <scene>
      <ambient>0.75 0.80 0.70 1</ambient>
      <background>0.45 0.70 0.90 1</background>
      <sky>
        <clouds>true</clouds>
      </sky>
      <shadows>true</shadows>
    </scene>

    <!-- Warm afternoon sun (low angle from south-west) -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 200 0 0 0</pose>
      <direction>-0.45 0.20 -0.87</direction>
      <diffuse>1.0 0.92 0.78 1</diffuse>
      <specular>0.35 0.30 0.25 1</specular>
      <attenuation>
        <range>2000</range>
        <constant>1.0</constant>
        <linear>0.0</linear>
        <quadratic>0.0</quadratic>
      </attenuation>
    </light>

    <!-- Soft sky-dome fill (no shadows, cool blue) -->
    <light type="directional" name="sky_fill">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 50 0 0 0</pose>
      <direction>0 0 -1</direction>
      <diffuse>0.35 0.45 0.60 1</diffuse>
      <specular>0.0 0.0 0.0 1</specular>
      <attenuation>
        <range>2000</range>
        <constant>1.0</constant>
        <linear>0.0</linear>
        <quadratic>0.0</quadratic>
      </attenuation>
    </light>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!--  Geolocation (same as iris_sprayer — Canberra, Australia)        -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <spherical_coordinates>
      <latitude_deg>-35.363262</latitude_deg>
      <longitude_deg>149.165237</longitude_deg>
      <elevation>584</elevation>
      <heading_deg>0</heading_deg>
      <surface_model>EARTH_WGS84</surface_model>
    </spherical_coordinates>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!--  Ground — grass field  1000 × 1000 m                               -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>1000 1000</size></plane>
          </geometry>
          <surface>
            <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="grass">
          <geometry>
            <plane><normal>0 0 1</normal><size>1000 1000</size></plane>
          </geometry>
          <material>
            <!-- Mid-tone grass green -->
            <ambient>0.25 0.40 0.15 1</ambient>
            <diffuse>0.30 0.48 0.18 1</diffuse>
            <specular>0.04 0.06 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!--  Crop rows  — 24 rows, 1.5 m pitch, 50 m long                   -->
    <!--  y range: -17.25 … +17.25 m  (step 1.5 m)                       -->
    <!--  Slightly darker / yellower green to contrast with bare grass    -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <model name="crop_field">
      <static>true</static>
      <link name="link">

        <visual name="row_00"><pose>0 -17.25 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_01"><pose>0 -15.75 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_02"><pose>0 -14.25 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_03"><pose>0 -12.75 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_04"><pose>0 -11.25 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_05"><pose>0 -9.75 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_06"><pose>0 -8.25 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_07"><pose>0 -6.75 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_08"><pose>0 -5.25 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_09"><pose>0 -3.75 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
