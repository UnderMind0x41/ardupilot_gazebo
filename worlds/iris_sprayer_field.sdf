          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_14"><pose>0 3.75 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_15"><pose>0 5.25 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
          <material><ambient>0.18 0.34 0.08 1</ambient><diffuse>0.20 0.38 0.09 1</diffuse></material></visual>

        <visual name="row_16"><pose>0 6.75 0.06 0 0 0</pose>
          <geometry><box><size>50 0.35 0.12</size></box></geometry>
