    <!-- Ring 2  r=130 -->
    <include><uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine Tree</uri>
      <name>f2_t01</name><pose>125.6 33.6 0 0 0 2.3</pose></include>
